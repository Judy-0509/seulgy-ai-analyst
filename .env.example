# 프론트엔드 PIN — /app, /db, /archive 접근 시 요구 (VITE_ 접두사 필수)
VITE_PIN_KEY=your_pin_here

# LLM Backend
LLM_BACKEND=glm

# Local/server startup should not run background scheduled collection unless explicitly enabled.
ENABLE_MI_NEWS_SCHEDULER=false

# GLM-4.7 (Zhipu AI)
ZHIPU_API_KEY=your_zhipu_api_key_here

# ─── GLM 모델 라우팅 (단계별 모델 override) ────────────────────────────────
# 기본 분석 모델 (suggest Pass 1 / 보고서 본문 생성)
GLM_ANALYSIS_MODEL=glm-4.7-flashx  # Stage A 쿼리 생성 (A/B 검증 2026-05-08: 4.7 동등 품질, 7x 저렴)
GLM_PASS1_MODEL=glm-4.7

# JSON 추출 / 태깅 (free tier)
GLM_EXTRACTION_MODEL=glm-4.5-flash

# Pass 2 enrichment (~10배 저렴)
GLM_ENRICH_MODEL=glm-4.7-flashx

# 목차 생성 Stage C (구조 설계 품질 우선 — A/B 검증 2026-05-08)
GLM_TOC_MODEL=glm-5.1

# 시사점 / Executive Summary (품질 우선)
GLM_FINAL_MODEL=glm-5.1

# ─── GLM concurrency 한도 (Zhipu 공식, https://z.ai/manage-apikey/rate-limits) ───
GLM_47_CONCURRENCY=2
GLM_FLASHX_CONCURRENCY=3
GLM_5_CONCURRENCY=2
GLM_51_CONCURRENCY=10
GLM_5_TURBO_CONCURRENCY=1
GLM_45_CONCURRENCY=10
GLM_45_AIR_CONCURRENCY=5
GLM_45_AIRX_CONCURRENCY=5
GLM_45_FLASH_CONCURRENCY=2
GLM_47_FLASH_CONCURRENCY=1
GLM_4_PLUS_CONCURRENCY=20
GLM_4_32B_CONCURRENCY=15

# 단일 GLM API 호출 timeout (초)
GLM_REQUEST_TIMEOUT_SECONDS=600

# Qwen3 (회사 서버 / DashScope)
# LLM_BACKEND=qwen 으로 변경하면 Qwen 백엔드 사용
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 회사 내부 서버면 해당 URL로 교체
QWEN_MODEL=qwen3-32b          # 메인 분석 모델 (회사 배포 모델명으로 교체)
QWEN_FAST_MODEL=qwen3-8b      # JSON 추출용 경량 모델
